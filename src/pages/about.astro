---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';

const values = [
  {
    title: 'Form Follows Function',
    description: 'Every element serves a purpose. We believe in design that communicates clearly without unnecessary decoration.',
    icon: 'square'
  },
  {
    title: 'Geometric Purity',
    description: 'Circles, squares, and triangles. Simple shapes create powerful visual impact when composed with intention.',
    icon: 'circle'
  },
  {
    title: 'Typography as Art',
    description: 'Text is not just content—it\'s a visual element. We treat typography with the respect it deserves.',
    icon: 'triangle'
  },
  {
    title: 'Craftsmanship',
    description: 'Quality matters. Every pixel, every line of code, every word is placed with intention and care.',
    icon: 'square'
  }
];

const skills = [
  'Design Systems',
  'Typography',
  'Web Development',
  'User Experience',
  'Visual Design',
  'CSS Art'
];
---

<BaseLayout title="About" description="Learn about our mission to bring Bauhaus design principles to modern web development.">
  <!-- Hero Section -->
  <section class="relative bg-primary-yellow border-b-4 border-black overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block bg-black text-xs font-bold uppercase tracking-widest text-white px-3 py-1 mb-6">
            Our Story
          </span>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-black uppercase tracking-tighter text-black leading-[0.9]">
            About<br/>
            <span class="text-primary-red">Us</span>
          </h1>
        </div>
        <div class="text-black/80">
          <p class="text-lg font-medium leading-relaxed">
            We are designers and developers united by a passion for timeless design principles.
            Our mission: make the wisdom of Bauhaus accessible to modern web creators.
          </p>
        </div>
      </div>
    </div>
    <!-- Geometric decorations -->
    <div class="absolute top-8 right-8 w-16 h-16 bg-primary-red shape-circle border-4 border-black"></div>
    <div class="absolute bottom-8 left-1/4 w-12 h-12 bg-primary-blue shape-square border-4 border-black"></div>
  </section>

  <!-- Mission Section -->
  <section class="bg-white border-b-4 border-black py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">
        <div>
          <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-black mb-6">
            Our Mission
          </h2>
          <div class="space-y-4 text-lg font-medium text-black/70 leading-relaxed">
            <p>
              The Bauhaus movement existed for only 14 years, yet its influence spans a century.
              Founded in Weimar, Germany in 1919, the Bauhaus school revolutionized how we think about design.
            </p>
            <p>
              We believe these principles are more relevant today than ever. In an age of visual clutter and design by committee,
              Bauhaus offers a path to clarity: reduce to the essential, execute with precision, and create with purpose.
            </p>
            <p>
              This blog is our contribution to keeping these ideas alive. Through articles, tutorials, and explorations,
              we share what we learn about applying Bauhaus wisdom to modern web development.
            </p>
          </div>
        </div>
        <div class="relative">
          <!-- Portrait placeholder with geometric composition -->
          <div class="aspect-[4/5] bg-muted border-4 border-black relative overflow-hidden">
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="text-center">
                <div class="w-32 h-32 mx-auto bg-primary-blue shape-circle border-4 border-black mb-4 flex items-center justify-center">
                  <span class="text-5xl font-black text-white">B</span>
                </div>
                <p class="font-bold uppercase tracking-wider">Bauhaus Blog</p>
              </div>
            </div>
            <!-- Geometric accents -->
            <div class="absolute top-4 left-4 w-8 h-8 bg-primary-red shape-square"></div>
            <div class="absolute bottom-4 right-4 w-6 h-6 bg-primary-yellow shape-circle border-2 border-black"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="bg-primary-red border-b-4 border-black py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white mb-12">
        Our Values
      </h2>
      <div class="grid md:grid-cols-2 gap-8">
        {values.map((value, index) => (
          <article class="bg-white border-4 border-black shadow-hard-lg p-8 card-lift">
            <div class="flex items-start gap-6">
              <div class={`w-16 h-16 flex-shrink-0 border-4 border-black flex items-center justify-center
                ${value.icon === 'circle' ? 'bg-primary-blue shape-circle' : ''}
                ${value.icon === 'square' ? 'bg-primary-yellow shape-square' : ''}
                ${value.icon === 'triangle' ? 'bg-primary-red shape-triangle' : ''}
              `}>
                <span class="font-black text-2xl text-white">
                  {index + 1}
                </span>
              </div>
              <div>
                <h3 class="text-xl font-black uppercase tracking-tight text-black mb-3">
                  {value.title}
                </h3>
                <p class="text-sm font-medium text-black/70 leading-relaxed">
                  {value.description}
                </p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills/Expertise Section -->
  <section class="bg-white border-b-4 border-black py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-black mb-8">
            Expertise
          </h2>
          <div class="flex flex-wrap gap-3">
            {skills.map(skill => (
              <span class="bg-primary-yellow text-sm font-bold uppercase px-4 py-2 border-2 border-black shadow-hard-sm">
                {skill}
              </span>
            ))}
          </div>
        </div>
        <div class="text-lg font-medium text-black/70 leading-relaxed">
          <p>
            Our expertise spans the full spectrum of digital design and development.
            From typography selection to responsive layouts, from color theory to interaction design,
            we bring a holistic approach to every project.
          </p>
          <p class="mt-4">
            But expertise is not the goal—clarity is. We use our skills not to impress,
            but to create experiences that serve users effectively.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-foreground border-b-4 border-black py-16 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white mb-6">
        Ready to Learn?
      </h2>
      <p class="text-lg font-medium text-white/70 mb-8">
        Explore our articles and discover how Bauhaus principles can transform your web design.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href="/blog" variant="yellow" size="lg">
          Read the Blog
        </Button>
        <Button href="/contact" variant="outline" size="lg">
          Get in Touch
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
