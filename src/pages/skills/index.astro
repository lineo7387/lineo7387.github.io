---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import { getCollection } from 'astro:content';
import { BASE } from '../../utils/base';
import { CATEGORY_COLORS } from '../../config/category-colors';
import { getSkillDisplayName } from '../../utils/post';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const plans = await getCollection('plans');

// 构建栏目数据（含进度）
const categories = allPosts.reduce((acc, post) => {
  const cat = post.data.category;
  if (!acc[cat]) {
    acc[cat] = { count: 0, planIds: new Set<string>() };
  }
  acc[cat].count++;
  if (post.data.planId) {
    acc[cat].planIds.add(post.data.planId);
  }
  return acc;
}, {} as Record<string, { count: number; planIds: Set<string> }>);

// 按名称排序
const sortedCategories = Object.entries(categories)
  .map(([name, data]) => {
    const plan = plans.find(p => p.data.skill?.toLowerCase() === name.toLowerCase());
    // completedInPlan: 有 planId 且在路线图计划内的文章数
    // totalInPlan: 路线图计划的总项目数
    const completedInPlan = plan
      ? [...data.planIds].filter(id => plan.data.planOrder?.includes(id)).length
      : 0;
    const totalInPlan = plan ? (plan.data.total ?? plan.data.planOrder?.length ?? 0) : 0;
    return {
      name,
      count: data.count,
      completedInPlan,
      totalInPlan,
      hasPlan: !!plan,
    };
  })
  .sort((a, b) => a.name.localeCompare(b.name));

---

<BaseLayout title="Skills" description="Browse all skill categories and their articles.">
  <!-- Hero Section -->
  <section class="relative bg-foreground border-b-4 border-border overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="grid lg:grid-cols-2 gap-12 items-end">
        <div>
          <span class="inline-block bg-brand-yellow text-xs font-bold uppercase tracking-widest text-on-brand-yellow px-3 py-1 mb-6">
            All Categories
          </span>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-black uppercase tracking-tighter text-hero-text leading-[0.9]">
            Skill<br />
            <span class="text-brand-yellow">Categories</span>
          </h1>
        </div>
        <div class="text-hero-text-muted">
          <p class="text-lg font-medium">
            {sortedCategories.length} skill{sortedCategories.length !== 1 ? 's' : ''} · {allPosts.length} article{allPosts.length !== 1 ? 's' : ''} total
          </p>
        </div>
      </div>
    </div>
    <!-- Geometric decorations -->
    <div class="absolute top-8 right-8 w-16 h-16 bg-brand-red shape-circle border-2 border-foreground/20"></div>
    <div class="absolute bottom-8 left-1/4 w-12 h-12 bg-brand-yellow shape-square border-2 border-foreground/20 rotate-45"></div>
  </section>

  <!-- Categories Grid -->
  <section class="bg-surface-raised border-b-4 border-foreground py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {sortedCategories.map((cat) => {
          const colors = CATEGORY_COLORS[cat.name.toLowerCase()] ?? CATEGORY_COLORS['python'];
          const displayName = getSkillDisplayName(cat.name);
          const progress = cat.hasPlan
            ? Math.round((cat.completedInPlan / cat.totalInPlan) * 100)
            : 100;

          return (
            <a
              href={`${BASE}/skills/${cat.name}`}
              class={`group relative border-4 border-foreground p-6 shadow-hard-md card-lift overflow-hidden flex flex-col
                ${colors.bg}
                ${colors.text}
              `}
            >
              <!-- Geometric decoration (top-right) -->
              <div class="absolute top-3 right-3 w-5 h-5 border-2 border-current opacity-20 shape-circle"></div>

              <!-- Content -->
              <div class="flex-1">
                <h2 class="text-xl md:text-2xl font-black uppercase tracking-tight mb-1">
                  {displayName}
                </h2>
                <p class={`text-xs font-medium opacity-70 mb-4`}>
                  {cat.count} article{cat.count !== 1 ? 's' : ''}
                </p>
              </div>

              <!-- Progress section (at bottom, with space for arrow) -->
              {cat.hasPlan ? (
                <div class="mt-auto pr-8">
                  <!-- Segmented progress bar (always 10 blocks) -->
                  <div class="flex gap-1 mb-2">
                    {Array.from({ length: 10 }, (_, i) => {
                      const filled = i < Math.round((cat.completedInPlan / cat.totalInPlan) * 10);
                      return (
                        <div
                          class={`flex-1 h-3 border-2 border-foreground transition-all duration-300
                            ${filled ? 'bg-current' : 'bg-transparent'}
                          `}
                        ></div>
                      );
                    })}
                  </div>
                  <div class="flex justify-between items-center">
                    <span class={`text-xs font-bold uppercase tracking-wider opacity-70`}>
                      {cat.completedInPlan}/{cat.totalInPlan}
                    </span>
                    <span class={`text-xs font-black opacity-90`}>
                      {progress}%
                    </span>
                  </div>
                </div>
              ) : (
                <div class="mt-auto h-6"></div>
              )}

              <!-- Arrow indicator (positioned in the reserved right space) -->
              <div class="absolute bottom-4 right-4 w-6 h-6 border-2 border-current flex items-center justify-center group-hover:bg-foreground group-hover:border-foreground transition-all">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="square" stroke-width="3" d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-muted border-b-4 border-foreground py-16 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-text mb-6">
        Looking for Something Specific?
      </h2>
      <p class="text-lg font-medium text-text/70 mb-8">
        Browse all articles or search by keyword.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href={`${BASE}/blog`} variant="primary" size="lg">
          Browse All Articles
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
