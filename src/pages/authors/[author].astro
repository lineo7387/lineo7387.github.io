---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogList from '../../components/blog/BlogList.astro';
import Button from '../../components/ui/Button.astro';
import authors from '../../data/authors.json';
import { getCollection } from 'astro:content';
import { BASE } from '../../utils/base';

interface Author {
  name: string;
  bio: string;
  role: string;
  twitter: string | null;
  github: string | null;
}

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const uniqueAuthors = [...new Set(allPosts.map(post => post.data.author))];
  const authorsTyped = authors as Record<string, Author>;

  return uniqueAuthors.map(author => ({
    params: { author: author.toLowerCase().replace(/\s+/g, '-') },
    props: { author, authorData: authorsTyped[author] ?? authorsTyped['Anonymous'] },
  }));
}

const { author, authorData } = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const authorPosts = allPosts
  .filter(post => post.data.author === author)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`${author} - Author`} description={`Articles by ${author}`}>
  <!-- Hero Section -->
  <section class="relative bg-primary-red border-b-4 border-black overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block bg-white text-xs font-bold uppercase tracking-widest text-black px-3 py-1 mb-6">
            Author
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black uppercase tracking-tighter text-white leading-[0.9] mb-4">
            {author}
          </h1>
          <p class="text-lg font-medium text-white/80">
            {authorData.role}
          </p>
        </div>
        <div class="text-white/80">
          <p class="text-lg font-medium leading-relaxed">
            {authorData.bio}
          </p>
          <div class="flex gap-4 mt-6">
            {authorData.twitter && (
              <a
                href={`https://twitter.com/${authorData.twitter.replace('@', '')}`}
                class="w-12 h-12 bg-white/10 border-2 border-white flex items-center justify-center hover:bg-primary-yellow hover:border-primary-yellow hover:text-black transition-all"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
            )}
            {authorData.github && (
              <a
                href={`https://github.com/${authorData.github}`}
                class="w-12 h-12 bg-white/10 border-2 border-white flex items-center justify-center hover:bg-primary-yellow hover:border-primary-yellow hover:text-black transition-all"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                </svg>
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
    <!-- Geometric decorations -->
    <div class="absolute top-0 right-0 w-24 h-24 bg-primary-yellow shape-triangle"></div>
    <div class="absolute bottom-8 left-8 w-16 h-16 bg-white/20 shape-circle"></div>
  </section>

  <!-- Author's Posts Section -->
  <section class="bg-white border-b-4 border-black py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-12">
        <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tight text-black">
          Articles by {author}
          <span class="text-primary-red ml-2">({authorPosts.length})</span>
        </h2>
        <Button href={`${BASE}/blog`} variant="outline" size="md">
          All Articles
        </Button>
      </div>

      {authorPosts.length > 0 ? (
        <BlogList posts={authorPosts} columns={3} />
      ) : (
        <div class="text-center py-16 bg-muted border-4 border-black">
          <p class="text-xl font-medium text-black/60">No articles found.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
