---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import { BASE } from '../utils/base';

const contacts = [
  {
    label: 'Email',
    value: 'lineo7387@gmail.com',
    href: 'mailto:lineo7387@gmail.com',
    description: '随时欢迎技术交流与讨论',
    icon: 'email',
    shape: 'circle',
    bgColor: 'bg-brand-red',
    textColor: 'text-on-brand-red',
  },
  {
    label: 'GitHub',
    value: '@lineo7387',
    href: 'https://github.com/lineo7387',
    description: '开源项目与代码实践',
    icon: 'github',
    shape: 'square',
    bgColor: 'bg-brand-blue',
    textColor: 'text-on-brand-blue',
  },
];
---

<BaseLayout title="Contact" description="联系 lineo — 通过 Email 或 GitHub 取得联系。">
  <!-- ═══════════════ Hero ═══════════════ -->
  <section class="relative bg-brand-blue border-b-4 border-foreground overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block bg-brand-yellow text-xs font-bold uppercase tracking-widest text-on-brand-yellow px-3 py-1 mb-6 anim-slide-left delay-hero-0">
            Get in Touch
          </span>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-black uppercase tracking-tighter text-hero-text leading-[0.9]">
            <span class="anim-line-pop delay-hero-80">Contact</span><br/>
            <span class="text-brand-yellow anim-line-pop delay-hero-150">Me</span>
          </h1>
        </div>
        <div class="text-hero-text-muted anim-slide-up delay-hero-200">
          <p class="text-lg font-medium leading-relaxed">
            有技术问题想讨论？发现文章中的错误？或者只是想打个招呼？
            通过下面的方式找到我，我会尽快回复。
          </p>
        </div>
      </div>
    </div>
    <!-- Geometric decorations -->
    <div class="absolute top-0 right-0 w-32 h-32 bg-brand-yellow shape-triangle anim-drop-in delay-hero-100"></div>
    <div class="absolute bottom-8 left-8 w-12 h-12 bg-background/20 shape-circle anim-circle-pop delay-hero-200"></div>
    <div class="absolute top-1/2 right-1/3 w-6 h-6 bg-brand-red shape-square border-2 border-foreground anim-scale-in delay-hero-300"></div>
  </section>

  <!-- ═══════════════ Contact Cards ═══════════════ -->
  <section class="bg-surface-raised border-b-4 border-foreground py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {contacts.map((contact, index) => (
          <a
            href={contact.href}
            target={contact.icon === 'github' ? '_blank' : undefined}
            rel={contact.icon === 'github' ? 'noopener noreferrer' : undefined}
            class={`group relative border-4 border-foreground shadow-hard-lg overflow-hidden scroll-anim anim-slide-up delay-${index * 100} block`}
          >
            <!-- Top: colored shape area -->
            <div class={`${contact.bgColor} ${contact.textColor} p-8 flex items-center justify-center relative overflow-hidden`}>
              <!-- Large geometric shape -->
              <div class={`w-20 h-20 ${contact.shape === 'circle' ? 'shape-circle' : ''} border-4 border-current flex items-center justify-center`}>
                {contact.icon === 'email' && (
                  <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="square">
                    <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                )}
                {contact.icon === 'github' && (
                  <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                  </svg>
                )}
              </div>
              <!-- Decorative accents -->
              <div class={`absolute top-3 right-3 w-4 h-4 ${contact.shape === 'circle' ? 'shape-square' : 'shape-circle'} border-2 border-current opacity-30`}></div>
              <div class={`absolute bottom-3 left-3 w-3 h-3 shape-triangle border-2 border-current opacity-20`}></div>
            </div>

            <!-- Bottom: info area -->
            <div class="bg-surface-raised p-6 group-hover:bg-brand-yellow transition-colors duration-200">
              <p class="text-xs font-bold uppercase tracking-widest text-muted mb-2">
                {contact.label}
              </p>
              <p class="text-xl font-black text-text mb-2 group-hover:text-text/80">
                {contact.value}
              </p>
              <p class="text-sm font-medium text-text/60 group-hover:text-text/70">
                {contact.description}
              </p>

              <!-- Arrow indicator -->
              <div class="mt-4 flex items-center gap-2 text-text/40 group-hover:text-text transition-colors">
                <span class="text-xs font-bold uppercase tracking-wider">
                  {contact.icon === 'email' ? 'Send Email' : 'Visit Profile'}
                </span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="square">
                  <path d="M5 12h14m-7-7l7 7-7 7" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ Geometric Closing ═══════════════ -->
  <section class="bg-brand-red border-b-4 border-foreground py-16 lg:py-24 relative overflow-hidden">
    <!-- Background decorations -->
    <div class="absolute top-0 left-0 w-40 h-40 bg-black/10 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-0 w-56 h-56 bg-black/10 rounded-full translate-x-1/3 translate-y-1/3"></div>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 scroll-anim anim-bounce-in delay-0">
      <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-on-brand-red mb-4 scroll-anim anim-line-pop delay-0">
        Let's Build Something
      </h2>
      <p class="text-lg font-medium text-hero-text-muted mb-8 scroll-anim anim-slide-up delay-100">
        无论是技术探讨、项目合作，还是单纯想聊聊代码与设计的交集。
      </p>
      <div class="flex flex-wrap justify-center gap-4 scroll-anim anim-scale-in delay-200">
        <Button href={`${BASE}/blog`} variant="yellow" size="lg">
          Explore Articles
        </Button>
        <Button href={`${BASE}/about`} variant="outline" size="lg">
          About Me
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
