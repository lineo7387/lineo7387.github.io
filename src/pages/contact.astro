---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';

const contactInfo = [
  {
    label: 'Email',
    value: 'lineo7387@gmail.com',
    href: 'mailto:lineo7387@gmail.com'
  },
  {
    label: 'GitHub',
    value: 'lineo7387',
    href: 'https://github.com/lineo7387'
  }
];
---

<BaseLayout title="Contact" description="Get in touch with us. We'd love to hear from you.">
  <!-- Hero Section -->
  <section class="relative bg-primary-blue border-b-4 border-black overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block bg-white text-xs font-bold uppercase tracking-widest text-black px-3 py-1 mb-6">
            Get in Touch
          </span>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-black uppercase tracking-tighter text-white leading-[0.9]">
            Contact<br/>
            <span class="text-primary-yellow">Us</span>
          </h1>
        </div>
        <div class="text-white/80">
          <p class="text-lg font-medium leading-relaxed">
            Have a question, suggestion, or just want to say hello?
            We'd love to hear from you. Fill out the form and we'll get back to you soon.
          </p>
        </div>
      </div>
    </div>
    <!-- Geometric decorations -->
    <div class="absolute top-0 right-0 w-32 h-32 bg-primary-yellow shape-triangle"></div>
    <div class="absolute bottom-8 left-8 w-12 h-12 bg-white/20 shape-circle"></div>
  </section>

  <!-- Contact Form and Info Section -->
  <section class="bg-white border-b-4 border-black py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-black uppercase tracking-tight text-black mb-8">
            Send a Message
          </h2>
          <form id="contact-form" class="space-y-6">
            <div>
              <label for="name" class="block text-sm font-bold uppercase tracking-wider text-black mb-2">
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-5 py-4 bg-white border-4 border-black font-medium text-black placeholder:text-black/40 focus:outline-none focus:border-primary-blue"
                placeholder="Your name"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-bold uppercase tracking-wider text-black mb-2">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-5 py-4 bg-white border-4 border-black font-medium text-black placeholder:text-black/40 focus:outline-none focus:border-primary-blue"
                placeholder="your@email.com"
              />
            </div>

            <div>
              <label for="subject" class="block text-sm font-bold uppercase tracking-wider text-black mb-2">
                Subject
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                required
                class="w-full px-5 py-4 bg-white border-4 border-black font-medium text-black placeholder:text-black/40 focus:outline-none focus:border-primary-blue"
                placeholder="What's this about?"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-bold uppercase tracking-wider text-black mb-2">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                class="w-full px-5 py-4 bg-white border-4 border-black font-medium text-black placeholder:text-black/40 focus:outline-none focus:border-primary-blue resize-none"
                placeholder="Your message..."
              ></textarea>
            </div>

            <Button type="submit" variant="primary" size="lg">
              Send Message
            </Button>
          </form>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-black uppercase tracking-tight text-black mb-8">
            Other Ways to Connect
          </h2>

          <div class="space-y-6 mb-12">
            {contactInfo.map(info => (
              <a
                href={info.href}
                class="flex items-center gap-4 p-6 bg-muted border-4 border-black shadow-hard-sm hover:bg-primary-yellow transition-colors group"
              >
                <div class="w-12 h-12 bg-primary-blue border-2 border-black flex items-center justify-center">
                  {info.label === 'Email' && (
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="square" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  )}
                  {info.label === 'Twitter' && (
                    <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                    </svg>
                  )}
                  {info.label === 'GitHub' && (
                    <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                    </svg>
                  )}
                </div>
                <div>
                  <p class="text-xs font-bold uppercase tracking-wider text-black/60 mb-1">
                    {info.label}
                  </p>
                  <p class="font-bold text-black group-hover:text-black/70">
                    {info.value}
                  </p>
                </div>
              </a>
            ))}
          </div>

          <!-- Geometric decoration -->
          <div class="relative aspect-video bg-muted border-4 border-black overflow-hidden">
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-24 h-24 bg-primary-red shape-circle border-4 border-black"></div>
              <div class="absolute w-16 h-16 bg-primary-blue shape-square border-4 border-black -translate-x-8 translate-y-4"></div>
              <div class="absolute w-12 h-12 bg-primary-yellow shape-triangle border-2 border-black translate-x-8 -translate-y-4"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert("Thanks for your message! We'll be in touch soon.");
  });
</script>
