---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import FeaturedPost from "../components/blog/FeaturedPost.astro";
import BlogList from "../components/blog/BlogList.astro";
import { getCollection } from "astro:content";
import { BASE } from "../utils/base";
import { sortByPlanOrder } from "../utils/post";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const planEntries = await getCollection("plans");

// Group by category, sort each group by planOrder
const categories = [
  ...new Set(allPosts.map((post) => post.data.category)),
].sort((a, b) => a.localeCompare(b));

const postsByCategory = Object.fromEntries(
  categories.map((cat) => {
    const catPosts = allPosts.filter((p) => p.data.category === cat);
    const plan = planEntries.find((p) => p.data.skill === cat);
    const planOrder = plan?.data.planOrder ?? [];
    return [cat, sortByPlanOrder(catPosts, planOrder)];
  }),
);

// Featured: first post in the first category
const featuredPost = postsByCategory[categories[0]]?.[0];

// Recent: remaining posts (all but featured), sorted by planOrder, limited to 2 rows (6 posts)
const recentPosts = categories
  .flatMap((cat) =>
    (postsByCategory[cat] ?? []).filter((p) => p.id !== featuredPost?.id),
  )
  .slice(0, 6);
---

<BaseLayout title="Home">
  <!-- Hero Section1 -->
  <section
    class="relative bg-surface-raised border-b-4 border-foreground overflow-hidden"
  >
    <div class="grid lg:grid-cols-2 min-h-[600px]">
      <!-- Left: Content -->
      <div
        class="flex flex-col justify-center px-4 sm:px-6 lg:px-8 py-16 lg:py-24 order-2 lg:order-1"
      >
        <div class="max-w-xl">
          <span
            class="inline-block bg-brand-yellow text-xs font-bold uppercase tracking-widest px-3 py-1 mb-6 anim-slide-left delay-hero-0"
          >
            Design Philosophy
          </span>
          <h1
            class="text-5xl sm:text-6xl lg:text-8xl font-black uppercase tracking-tighter leading-[0.9] text-text mb-6 [&>span]:block"
          >
            <span class="anim-line-pop delay-hero-80">Code<br /></span>
            <span class="text-brand-red anim-line-pop delay-hero-150">Meets</span><br />
            <span class="anim-line-pop delay-hero-230">Design</span>
          </h1>
          <p
            class="text-lg font-medium text-text/70 leading-relaxed mb-8 max-w-md anim-slide-up delay-hero-310"
          >
            A personal tech blog exploring web development, design systems, and
            the craft of building modern applications.
          </p>
          <div class="flex flex-wrap gap-4 anim-slide-up delay-hero-390">
            <Button href={`${BASE}/blog`} variant="primary" size="lg">
              Explore Articles
            </Button>
            <Button href={`${BASE}/about`} variant="outline" size="lg">
              Learn More
            </Button>
          </div>
        </div>
      </div>

      <!-- Right: Geometric Composition -->
      <div
        class="relative bg-brand-blue border-t-4 lg:border-t-0 lg:border-l-4 border-foreground min-h-[300px] lg:min-h-0 order-1 lg:order-2 overflow-hidden"
      >
        <div class="absolute inset-0 flex items-center justify-center">
          <!-- Large circle -->
          <div
            class="absolute w-48 h-48 md:w-64 md:h-64 bg-foreground/20 rounded-full border-4 border-foreground anim-circle-pop delay-hero-100"
          >
          </div>
          <!-- Overlapping rotated square -->
          <div
            class="absolute w-36 h-36 md:w-48 md:h-48 bg-brand-yellow/80 border-4 border-foreground rotate-45 anim-square-spin delay-hero-200"
          >
          </div>
          <!-- Centered square -->
          <div
            class="absolute w-24 h-24 md:w-32 md:h-32 bg-inverse-surface border-4 border-foreground flex items-center justify-center anim-scale-in delay-hero-300"
          >
            <div class="w-12 h-12 md:w-16 md:h-16 bg-brand-red shape-triangle">
            </div>
          </div>
          <!-- Small decorative circles -->
          <div
            class="absolute top-8 right-8 w-8 h-8 bg-brand-yellow border-2 border-foreground rounded-full anim-dot-pop delay-hero-400"
          >
          </div>
          <div
            class="absolute bottom-12 left-12 w-6 h-6 bg-inverse-surface border-2 border-foreground rounded-full anim-dot-pop delay-hero-480"
          >
          </div>
        </div>
        <!-- Geometric decorations -->
        <div
          class="absolute top-0 left-0 w-16 h-16 bg-brand-red shape-triangle anim-drop-in delay-hero-50"
        >
        </div>
        <div
          class="absolute bottom-0 right-0 w-12 h-12 bg-brand-yellow border-l-4 border-t-4 border-foreground anim-square-spin delay-hero-0"
        >
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Post Section -->
  {
    featuredPost && (
      <section class="bg-brand-yellow border-b-4 border-foreground py-16 lg:py-24 overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center gap-4 mb-8">
            <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tight text-text scroll-anim anim-line-pop delay-0">
              Featured Article
            </h2>
            <div class="flex-1 h-4 bg-foreground scroll-anim anim-slide-up delay-50" />
          </div>
          <div class="scroll-anim anim-slide-up delay-100">
            <FeaturedPost
            title={featuredPost.data.title}
            excerpt={featuredPost.data.description}
            date={featuredPost.data.pubDate}
            id={featuredPost.id}
            image={featuredPost.data.heroImage}
            category={featuredPost.data.category}
            author={featuredPost.data.author}
            />
          </div>
        </div>
      </section>
    )
  }

  <!-- Recent Posts Section -->
  <section class="bg-brand-blue border-b-4 border-foreground py-16 lg:py-24 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h2
          class="text-2xl md:text-3xl font-black uppercase tracking-tight text-hero-text scroll-anim anim-slide-left delay-0"
        >
          Recent Articles
        </h2>
        <Button href={`${BASE}/blog`} variant="yellow" size="md" class="scroll-anim anim-scale-in delay-100">
          View All
        </Button>
      </div>
      <div class="scroll-anim anim-slide-up delay-0">
        <BlogList posts={recentPosts} columns={3} allPosts={allPosts} />
      </div>
    </div>
  </section>

  <!-- About Preview Section -->
  <section
    class="bg-surface-raised border-b-4 border-foreground py-16 lg:py-24 overflow-hidden"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="scroll-anim anim-slide-left delay-0">
          <span
            class="inline-block bg-brand-red text-xs font-bold uppercase tracking-widest text-on-brand-red px-3 py-1 mb-6"
          >
            About Us
          </span>
          <h2
            class="text-4xl md:text-5xl font-black uppercase tracking-tight text-text mb-6 leading-[0.95] scroll-anim anim-line-pop delay-100"
          >
            Building<br />
            <span class="text-brand-blue">with Care</span>
          </h2>
          <p class="text-lg font-medium text-text/70 leading-relaxed mb-8 scroll-anim anim-slide-up delay-200">
            I write about web development, design systems, and the craft of
            building meaningful digital experiences. Every article is crafted to
            help you create better, more thoughtful applications.
          </p>
          <Button href={`${BASE}/about`} variant="secondary" size="lg" class="scroll-anim anim-scale-in delay-300">
            Our Story
          </Button>
        </div>
        <div class="relative scroll-anim anim-slide-right delay-150">
          <!-- Geometric composition for about preview -->
          <div
            class="aspect-square bg-muted border-4 border-foreground p-8 relative overflow-hidden"
          >
            <div
              class="absolute top-4 right-4 w-16 h-16 bg-brand-red shape-circle"
            >
            </div>
            <div
              class="absolute bottom-4 left-4 w-12 h-12 bg-brand-blue shape-square border-2 border-foreground"
            >
            </div>
            <div
              class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-24 h-24 bg-brand-yellow shape-circle border-4 border-foreground"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA Section -->
  <section
    class="bg-brand-red border-b-4 border-foreground py-16 lg:py-24 relative overflow-hidden"
  >
    <!-- Background decorations -->
    <div
      class="absolute top-0 left-0 w-32 h-32 bg-black/10 rounded-full -translate-x-1/2 -translate-y-1/2"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 w-48 h-48 bg-black/10 rounded-full translate-x-1/3 translate-y-1/3"
    >
    </div>

    <div
      class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 scroll-anim anim-bounce-in delay-0"
    >
      <h2
        class="text-4xl md:text-5xl font-black uppercase tracking-tight text-hero-text mb-4 scroll-anim anim-slide-up delay-0"
      >
        Stay Updated
      </h2>
      <p class="text-lg font-medium text-hero-text-muted mb-8 scroll-anim anim-slide-up delay-100">
        Get the latest articles on web development and design delivered to your
        inbox. No spam, just thoughtful content.
      </p>
      <form
        id="newsletter-form"
        class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto scroll-anim anim-slide-up delay-200"
      >
        <input
          type="email"
          placeholder="Enter your email"
          required
          class="flex-1 px-5 py-4 bg-surface-raised border-4 border-foreground font-medium text-text placeholder:text-muted focus:outline-none focus:border-brand-yellow"
        />
        <Button type="submit" variant="yellow" size="lg"> Subscribe </Button>
      </form>
      <p class="text-sm font-medium text-hero-text-muted mt-4 scroll-anim anim-slide-up delay-300">
        Join developers learning together
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById("newsletter-form");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    alert("Thanks for subscribing!");
  });
</script>
