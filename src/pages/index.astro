---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import FeaturedPost from '../components/blog/FeaturedPost.astro';
import BlogList from '../components/blog/BlogList.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPost = sortedPosts.find(post => post.data.featured) || sortedPosts[0];
const recentPosts = sortedPosts.filter(post => post.id !== featuredPost?.id).slice(0, 6);
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="relative bg-white border-b-4 border-black overflow-hidden">
    <div class="grid lg:grid-cols-2 min-h-[600px]">
      <!-- Left: Content -->
      <div class="flex flex-col justify-center px-4 sm:px-6 lg:px-8 py-16 lg:py-24 order-2 lg:order-1">
        <div class="max-w-xl">
          <span class="inline-block bg-primary-yellow text-xs font-bold uppercase tracking-widest px-3 py-1 mb-6">
            Design Philosophy
          </span>
          <h1 class="text-5xl sm:text-6xl lg:text-8xl font-black uppercase tracking-tighter leading-[0.9] text-black mb-6">
            Form<br/>
            <span class="text-primary-red">Follows</span><br/>
            Function
          </h1>
          <p class="text-lg font-medium text-black/70 leading-relaxed mb-8 max-w-md">
            Explore the timeless principles of Bauhaus design. Where geometric purity meets modern web craft.
          </p>
          <div class="flex flex-wrap gap-4">
            <Button href="/blog" variant="primary" size="lg">
              Explore Articles
            </Button>
            <Button href="/about" variant="outline" size="lg">
              Learn More
            </Button>
          </div>
        </div>
      </div>

      <!-- Right: Geometric Composition -->
      <div class="relative bg-primary-blue border-t-4 lg:border-t-0 lg:border-l-4 border-black min-h-[300px] lg:min-h-0 order-1 lg:order-2">
        <div class="absolute inset-0 flex items-center justify-center">
          <!-- Large circle -->
          <div class="absolute w-48 h-48 md:w-64 md:h-64 bg-white/20 rounded-full border-4 border-white"></div>
          <!-- Overlapping rotated square -->
          <div class="absolute w-36 h-36 md:w-48 md:h-48 bg-primary-yellow/80 border-4 border-black rotate-45"></div>
          <!-- Centered square -->
          <div class="absolute w-24 h-24 md:w-32 md:h-32 bg-white border-4 border-black flex items-center justify-center">
            <div class="w-12 h-12 md:w-16 md:h-16 bg-primary-red shape-triangle"></div>
          </div>
          <!-- Small decorative circles -->
          <div class="absolute top-8 right-8 w-8 h-8 bg-primary-yellow border-2 border-black rounded-full"></div>
          <div class="absolute bottom-12 left-12 w-6 h-6 bg-white border-2 border-black rounded-full"></div>
        </div>
        <!-- Geometric decorations -->
        <div class="absolute top-0 left-0 w-16 h-16 bg-primary-red shape-triangle"></div>
        <div class="absolute bottom-0 right-0 w-12 h-12 bg-primary-yellow border-l-4 border-t-4 border-black"></div>
      </div>
    </div>
  </section>

  <!-- Featured Post Section -->
  {featuredPost && (
    <section class="bg-primary-yellow border-b-4 border-black py-16 lg:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tight text-black">
            Featured Article
          </h2>
          <div class="flex-1 h-4 bg-black"></div>
        </div>
        <FeaturedPost
          title={featuredPost.data.title}
          excerpt={featuredPost.data.description}
          date={featuredPost.data.pubDate}
          slug={featuredPost.id}
          image={featuredPost.data.heroImage}
          category={featuredPost.data.category}
          author={featuredPost.data.author}
        />
      </div>
    </section>
  )}

  <!-- Recent Posts Section -->
  <section class="bg-primary-blue border-b-4 border-black py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tight text-white">
          Recent Articles
        </h2>
        <Button href="/blog" variant="yellow" size="md">
          View All
        </Button>
      </div>
      <BlogList posts={recentPosts} columns={3} />
    </div>
  </section>

  <!-- About Preview Section -->
  <section class="bg-white border-b-4 border-black py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block bg-primary-red text-xs font-bold uppercase tracking-widest text-white px-3 py-1 mb-6">
            About Us
          </span>
          <h2 class="text-4xl md:text-5xl font-black uppercase tracking-tight text-black mb-6 leading-[0.95]">
            Design Meets<br/>
            <span class="text-primary-blue">Code</span>
          </h2>
          <p class="text-lg font-medium text-black/70 leading-relaxed mb-8">
            We explore the intersection of timeless design principles and modern web development.
            Every article is crafted to help you create better, more meaningful digital experiences.
          </p>
          <Button href="/about" variant="secondary" size="lg">
            Our Story
          </Button>
        </div>
        <div class="relative">
          <!-- Geometric composition for about preview -->
          <div class="aspect-square bg-muted border-4 border-black p-8 relative overflow-hidden">
            <div class="absolute top-4 right-4 w-16 h-16 bg-primary-red shape-circle"></div>
            <div class="absolute bottom-4 left-4 w-12 h-12 bg-primary-blue shape-square border-2 border-black"></div>
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-24 h-24 bg-primary-yellow shape-circle border-4 border-black"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA Section -->
  <section class="bg-primary-red border-b-4 border-black py-16 lg:py-24 relative overflow-hidden">
    <!-- Background decorations -->
    <div class="absolute top-0 left-0 w-32 h-32 bg-black/10 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-0 w-48 h-48 bg-black/10 rounded-full translate-x-1/3 translate-y-1/3"></div>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <h2 class="text-4xl md:text-5xl font-black uppercase tracking-tight text-white mb-4">
        Stay Updated
      </h2>
      <p class="text-lg font-medium text-white/80 mb-8">
        Get the latest design insights delivered to your inbox. No spam, just thoughtful content.
      </p>
      <form class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto" onsubmit="event.preventDefault(); alert('Thanks for subscribing!');">
        <input
          type="email"
          placeholder="Enter your email"
          required
          class="flex-1 px-5 py-4 bg-white border-4 border-black font-medium text-black placeholder:text-black/40 focus:outline-none focus:border-primary-yellow"
        />
        <Button type="submit" variant="yellow" size="lg">
          Subscribe
        </Button>
      </form>
      <p class="text-sm font-medium text-white/60 mt-4">
        Join 1,000+ designers and developers
      </p>
    </div>
  </section>
</BaseLayout>
