---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogList from "../../components/blog/BlogList.astro";
import CategoryFilter from "../../components/blog/CategoryFilter.astro";
import Pagination from "../../components/blog/Pagination.astro";
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import { BASE } from "../../utils/base";
import { sortByPlanOrder } from "../../utils/post";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const planEntries = await getCollection("plans");

  const categories = [...new Set(allPosts.map((post) => post.data.category))].sort((a, b) =>
    a.localeCompare(b),
  );

  const allSorted = categories.flatMap((cat) => {
    const plan = planEntries.find((p) => p.data.skill?.toLowerCase() === cat.toLowerCase());
    return sortByPlanOrder(
      allPosts.filter((p) => p.data.category === cat),
      plan?.data.planOrder ?? [],
    );
  });

  const postsPerPage = 6;
  const paths = [];

  // Individual post pages
  for (const post of allPosts) {
    paths.push({
      params: { slug: post.id },
      props: { type: "post", post, category: "", page: 1, allSorted, allPosts, planEntries, categories },
    });
  }

  // /blog/2, /blog/3, ... (pagination for all posts)
  const totalAllPages = Math.ceil(allSorted.length / postsPerPage);
  for (let page = 2; page <= totalAllPages; page++) {
    paths.push({
      params: { slug: String(page) },
      props: { type: "pagination", category: "", page, allSorted, planEntries, categories },
    });
  }

  // /blog/:category and /blog/:category/:page
  for (const c of categories) {
    const catSlug = c.toLowerCase();
    const catPosts = allSorted.filter((p) => p.data.category === c);
    paths.push({
      params: { slug: catSlug },
      props: { type: "category", category: c, page: 1, allSorted, planEntries, categories },
    });
    const catTotal = Math.ceil(catPosts.length / postsPerPage);
    for (let page = 2; page <= catTotal; page++) {
      paths.push({
        params: { slug: `${catSlug}/${page}` },
        props: { type: "category", category: c, page, allSorted, planEntries, categories },
      });
    }
  }

  return paths.map((p) => ({
    ...p,
    props: { ...p.props, postsPerPage: 6 },
  }));
}

const { type, post, category, page, allSorted, allPosts, planEntries, categories, postsPerPage } = Astro.props as {
  type: "post" | "pagination" | "category";
  post: CollectionEntry<"blog"> | undefined;
  category: string;
  page: number;
  allSorted: CollectionEntry<"blog">[];
  allPosts: CollectionEntry<"blog">[];
  planEntries: CollectionEntry<"plans">[];
  categories: string[];
  postsPerPage: number;
};

const currentCategory = category || "";

let filteredPosts = allSorted;
let currentPage = page || 1;
let totalPages = 1;
let totalFilteredCount = allSorted.length;

if (type === "category" && category) {
  filteredPosts = allSorted.filter(
    (p) => p.data.category.toLowerCase() === category.toLowerCase(),
  );
  totalFilteredCount = filteredPosts.length;
  totalPages = Math.ceil(filteredPosts.length / postsPerPage);
  const startIndex = ((page || 1) - 1) * postsPerPage;
  filteredPosts = filteredPosts.slice(startIndex, startIndex + postsPerPage);
} else if (type === "pagination") {
  totalPages = Math.ceil(allSorted.length / postsPerPage);
  const startIndex = ((page || 1) - 1) * postsPerPage;
  filteredPosts = allSorted.slice(startIndex, startIndex + postsPerPage);
}

const rendered = type === "post" && post ? await render(post) : null;
const PostContent = rendered?.Content;
const headings = rendered?.headings ?? [];

// PostNavigation: use planOrder within the same category
const postCategory = post?.data.category ?? "";
const plan = planEntries.find((p) => p.data.skill?.toLowerCase() === postCategory.toLowerCase());
const planOrder = plan?.data.planOrder;

let prevPost: typeof post | undefined;
let nextPost: typeof post | undefined;
let prevIndex: number | undefined;
let nextIndex: number | undefined;

if (planOrder && planOrder.length > 0) {
  const catSorted = allSorted.filter((p) => p.data.category === postCategory);
  const currentIdx = post ? catSorted.findIndex((p) => p.id === post.id) : -1;
  prevPost = currentIdx > 0 ? catSorted[currentIdx - 1] : undefined;
  nextPost = currentIdx >= 0 && currentIdx < catSorted.length - 1
    ? catSorted[currentIdx + 1]
    : undefined;
  prevIndex = currentIdx > 0 ? currentIdx - 1 : undefined;
  nextIndex = currentIdx >= 0 && currentIdx < catSorted.length - 1
    ? currentIdx + 1
    : undefined;
} else {
  const catPosts = allSorted
    .filter((p) => p.data.category === postCategory)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  const currentIndex = post ? catPosts.findIndex((p) => p.id === post.id) : -1;
  prevPost = currentIndex > 0 ? catPosts[currentIndex - 1] : undefined;
  nextPost = currentIndex < catPosts.length - 1 && currentIndex !== -1
    ? catPosts[currentIndex + 1]
    : undefined;
}

type PostContentType = (props?: Record<string, unknown>) => unknown;
const PostContentComponent = PostContent as PostContentType;
---

{type === "post" ? (
  <BlogPostLayout
    id={post!.id}
    title={post!.data.title}
    description={post!.data.description}
    pubDate={post!.data.pubDate}
    updatedDate={post!.data.updatedDate}
    heroImage={post!.data.heroImage}
    category={post!.data.category}
    tags={post!.data.tags}
    author={post!.data.author}
    readingTime={post!.data.readingTime}
    headings={headings}
    prevPost={prevPost}
    nextPost={nextPost}
    prevIndex={prevIndex}
    nextIndex={nextIndex}
    comments={post!.data.comments}
  >
    <PostContentComponent />
  </BlogPostLayout>
) : (
  <BaseLayout
    title={category ? `${category} - Blog` : `Page ${page} - Blog`}
    description="Explore our collection of articles on design, typography, and web development."
  >
    <!-- Hero Section -->
    <section class="relative bg-foreground border-b-4 border-border overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
        <div class="grid lg:grid-cols-2 gap-12 items-end">
          <div>
            <span class="inline-block bg-brand-yellow text-xs font-bold uppercase tracking-widest text-on-brand-yellow px-3 py-1 mb-6">
              {category || "All Articles"}
            </span>
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-black uppercase tracking-tighter text-hero-text leading-[0.9]">
              The<br />
              <span class="text-brand-yellow">Blog</span>
            </h1>
          </div>
          <div class="text-hero-text-muted">
            <p class="text-lg font-medium">
              Discover {totalFilteredCount} article{totalFilteredCount !== 1 ? "s" : ""}
              {category ? ` in ${category}` : ""}.
            </p>
          </div>
        </div>
      </div>
      <div class="absolute top-8 right-8 w-16 h-16 bg-brand-red shape-circle border-2 border-foreground/20"></div>
      <div class="absolute bottom-8 left-1/4 w-12 h-12 bg-brand-yellow shape-square border-2 border-foreground/20 rotate-45"></div>
    </section>

    <!-- Filters Section -->
    <section class="bg-muted border-b-4 border-foreground py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row gap-6 items-start md:items-center justify-between">
          <CategoryFilter categories={categories} activeCategory={currentCategory} />
          <div class="flex items-center gap-2">
            <input
              type="text"
              id="search-input"
              placeholder="Search articles..."
              class="px-4 py-2 bg-surface-raised border-2 border-foreground font-medium text-sm text-text focus:outline-none focus:border-brand-yellow"
            />
            <button
              id="search-btn"
              class="px-4 py-2 bg-brand-blue text-on-brand-blue border-2 border-foreground font-bold text-sm uppercase hover:bg-brand-blue/90 transition-colors btn-press"
            >
              Search
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Posts Grid -->
    <section class="bg-surface-raised py-16 lg:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div id="posts-container">
          <BlogList posts={filteredPosts} columns={3} allPosts={allPosts} />
        </div>
        <div class="mt-16 lg:mt-24">
          <Pagination
            currentPage={currentPage}
            totalPages={totalPages}
            baseUrl={`${BASE}/blog`}
            category={currentCategory}
          />
        </div>
        {filteredPosts.length === 0 && (
          <div class="text-center py-16">
            <p class="text-xl font-medium text-muted">No articles found.</p>
          </div>
        )}
      </div>
    </section>
  </BaseLayout>
)}

<script is:inline define:vars={{ BASE }}>
  const searchBtn = document.getElementById('search-btn');
  const searchInput = document.getElementById('search-input');
  searchBtn?.addEventListener('click', () => {
    const query = searchInput?.value.trim();
    if (query) {
      window.location.href = `${BASE}/blog?q=${encodeURIComponent(query)}`;
    }
  });
  searchInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter' && searchInput) {
      const query = searchInput.value.trim();
      if (query) {
        window.location.href = `${BASE}/blog?q=${encodeURIComponent(query)}`;
      }
    }
  });
</script>
