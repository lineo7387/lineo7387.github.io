---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogList from "../../components/blog/BlogList.astro";
import CategoryFilter from "../../components/blog/CategoryFilter.astro";
import Pagination from "../../components/blog/Pagination.astro";
import { getCollection } from "astro:content";
import { BASE } from "../../utils/base";
import { sortByPlanOrder } from "../../utils/post";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const planEntries = await getCollection("plans");

// Group by category, sort each group by planOrder
const categories = [...new Set(allPosts.map((post) => post.data.category))].sort((a, b) =>
  a.localeCompare(b),
);

const allSorted = categories.flatMap((cat) => {
  const plan = planEntries.find((p) => p.data.skill?.toLowerCase() === cat.toLowerCase());
  return sortByPlanOrder(
    allPosts.filter((p) => p.data.category === cat),
    plan?.data.planOrder ?? [],
  );
});

const postsPerPage = 6;
const totalPages = Math.ceil(allSorted.length / postsPerPage);
const paginatedPosts = allSorted.slice(0, postsPerPage);
---

<BaseLayout
  title="Blog"
  description="Explore our collection of articles on design, typography, and web development."
>
  <!-- Hero Section -->
  <section
    class="relative bg-foreground border-b-4 border-border overflow-hidden"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="grid lg:grid-cols-2 gap-12 items-end">
        <div>
          <span
            class="inline-block bg-brand-yellow text-xs font-bold uppercase tracking-widest text-on-brand-yellow px-3 py-1 mb-6"
          >
            All Articles
          </span>
          <h1
            class="text-5xl md:text-6xl lg:text-7xl font-black uppercase tracking-tighter text-hero-text leading-[0.9]"
          >
            The<br />
            <span class="text-brand-yellow">Blog</span>
          </h1>
        </div>
        <div class="text-hero-text-muted">
          <p class="text-lg font-medium">
            Discover {allSorted.length} article{
              allSorted.length !== 1 ? "s" : ""
            }.
          </p>
        </div>
      </div>
    </div>
    <!-- Geometric decorations -->
    <div
      class="absolute top-8 right-8 w-16 h-16 bg-brand-red shape-circle border-2 border-foreground/20"
    >
    </div>
    <div
      class="absolute bottom-8 left-1/4 w-12 h-12 bg-brand-yellow shape-square border-2 border-foreground/20 rotate-45"
    >
    </div>
  </section>

  <!-- Filters Section -->
  <section class="bg-muted border-b-4 border-foreground py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="flex flex-col md:flex-row gap-6 items-start md:items-center justify-between"
      >
        <CategoryFilter categories={categories} activeCategory="" />
        <div class="flex items-center gap-2">
          <input
            type="text"
            id="search-input"
            placeholder="Search articles..."
            class="px-4 py-2 bg-surface-raised border-2 border-foreground font-medium text-sm text-text focus:outline-none focus:border-brand-yellow"
          />
          <button
            id="search-btn"
            class="px-4 py-2 bg-brand-blue text-on-brand-blue border-2 border-foreground font-bold text-sm uppercase hover:bg-brand-blue/90 transition-colors btn-press"
          >
            Search
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="bg-surface-raised py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div id="posts-container">
        <BlogList posts={paginatedPosts} columns={3} allPosts={allSorted} />
      </div>

      <div class="mt-16 lg:mt-24">
        <Pagination
          currentPage={1}
          totalPages={totalPages}
          baseUrl={`${BASE}/blog`}
          category=""
        />
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ BASE }}>
  const searchBtn = document.getElementById("search-btn");
  const searchInput = document.getElementById("search-input");

  searchBtn?.addEventListener("click", () => {
    const query = searchInput?.value.trim();
    if (query) {
      window.location.href = `${BASE}/blog?q=${encodeURIComponent(query)}`;
    }
  });

  searchInput?.addEventListener("keypress", (e) => {
    if (e.key === "Enter") {
      const query = searchInput.value.trim();
      if (query) {
        window.location.href = `${BASE}/blog?q=${encodeURIComponent(query)}`;
      }
    }
  });
</script>
