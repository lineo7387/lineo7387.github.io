---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogList from "../../components/blog/BlogList.astro";
import CategoryFilter from "../../components/blog/CategoryFilter.astro";
import Pagination from "../../components/blog/Pagination.astro";
import { getCollection } from "astro:content";
import { BASE } from "../../utils/base";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categories = [...new Set(sortedPosts.map((post) => post.data.category))];
const postsPerPage = 6;
const totalPages = Math.ceil(sortedPosts.length / postsPerPage);
const paginatedPosts = sortedPosts.slice(0, postsPerPage);
---

<BaseLayout
  title="Blog"
  description="Explore our collection of articles on design, typography, and web development."
>
  <!-- Hero Section -->
  <section
    class="relative bg-foreground border-b-4 border-black overflow-hidden"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="grid lg:grid-cols-2 gap-12 items-end">
        <div>
          <span
            class="inline-block bg-primary-yellow text-xs font-bold uppercase tracking-widest text-black px-3 py-1 mb-6"
          >
            All Articles
          </span>
          <h1
            class="text-5xl md:text-6xl lg:text-7xl font-black uppercase tracking-tighter text-white leading-[0.9]"
          >
            The<br />
            <span class="text-primary-yellow">Blog</span>
          </h1>
        </div>
        <div class="text-white/70">
          <p class="text-lg font-medium">
            Discover {sortedPosts.length} article{
              sortedPosts.length !== 1 ? "s" : ""
            }.
          </p>
        </div>
      </div>
    </div>
    <!-- Geometric decorations -->
    <div
      class="absolute top-8 right-8 w-16 h-16 bg-primary-red shape-circle border-2 border-white/20"
    >
    </div>
    <div
      class="absolute bottom-8 left-1/4 w-12 h-12 bg-primary-yellow shape-square border-2 border-white/20 rotate-45"
    >
    </div>
  </section>

  <!-- Filters Section -->
  <section class="bg-muted border-b-4 border-black py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="flex flex-col md:flex-row gap-6 items-start md:items-center justify-between"
      >
        <CategoryFilter categories={categories} activeCategory="" />
        <div class="flex items-center gap-2">
          <input
            type="text"
            id="search-input"
            placeholder="Search articles..."
            class="px-4 py-2 bg-white border-2 border-black font-medium text-sm focus:outline-none focus:border-primary-yellow"
          />
          <button
            id="search-btn"
            class="px-4 py-2 bg-primary-blue text-white border-2 border-black font-bold text-sm uppercase hover:bg-primary-blue/90 transition-colors btn-press"
          >
            Search
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="bg-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div id="posts-container">
        <BlogList posts={paginatedPosts} columns={3} />
      </div>

      <div class="mt-16 lg:mt-24">
        <Pagination
          currentPage={1}
          totalPages={totalPages}
          baseUrl={`${BASE}/blog`}
          category=""
        />
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ BASE }}>
  const searchBtn = document.getElementById("search-btn");
  const searchInput = document.getElementById("search-input");

  searchBtn?.addEventListener("click", () => {
    const query = searchInput?.value.trim();
    if (query) {
      window.location.href = `${BASE}/blog?q=${encodeURIComponent(query)}`;
    }
  });

  searchInput?.addEventListener("keypress", (e) => {
    if (e.key === "Enter") {
      const query = searchInput.value.trim();
      if (query) {
        window.location.href = `${BASE}/blog?q=${encodeURIComponent(query)}`;
      }
    }
  });
</script>
