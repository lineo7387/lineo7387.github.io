---
import { BASE } from '../../utils/base';

interface Props {
  title: string;
  excerpt: string;
  date: Date;
  slug: string;
  image?: string;
  category: string;
  categoryIndex?: number;
  class?: string;
}

const { title, excerpt, date, slug, image, category, categoryIndex, class: className = '' } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});

const categoryColors: Record<string, { bg: string; text: string; hover: string }> = {
  python:      { bg: 'bg-primary-blue',        text: 'text-white',    hover: 'hover:text-primary-blue' },
  react:       { bg: 'bg-primary-react',       text: 'text-foreground', hover: 'hover:text-primary-react' },
  'react-native': { bg: 'bg-primary-reactnative', text: 'text-foreground', hover: 'hover:text-primary-reactnative' },
  vue:         { bg: 'bg-primary-vue',        text: 'text-white',    hover: 'hover:text-primary-vue' },
  java:        { bg: 'bg-primary-orange',      text: 'text-white',    hover: 'hover:text-primary-orange' },
  springboot:  { bg: 'bg-primary-green',       text: 'text-white',    hover: 'hover:text-primary-green' },
  design:      { bg: 'bg-foreground',         text: 'text-white',    hover: 'hover:text-foreground' },
};
const colors = categoryColors[category] ?? { bg: 'bg-primary-blue', text: 'text-white', hover: 'hover:text-primary-blue' };
---

<article class={`bg-white border-4 border-black shadow-hard-lg card-lift relative overflow-hidden ${className}`}>
  <!-- Geometric decoration in corner -->
  <div class={`absolute top-0 right-0 w-6 h-6 shape-square z-10 ${colors.bg}`}></div>

  {image && (
    <div class="aspect-video overflow-hidden border-b-4 border-black">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover img-bauhaus"
      />
    </div>
  )}

  <div class="p-6">
    <div class="flex items-center justify-between gap-3 mb-4">
      <div class="flex items-center gap-3">
        <span class={`text-xs font-bold uppercase tracking-wider px-2 py-1 ${colors.bg} ${colors.text}`}>
          {category}
        </span>
        <time class="text-xs font-medium text-black/60" datetime={date.toISOString()}>
          {formattedDate}
        </time>
      </div>
      {categoryIndex !== undefined && (
        <span class="text-xs font-black text-black/40">
          #{categoryIndex}
        </span>
      )}
    </div>

    <h3 class="text-xl font-black uppercase tracking-tight mb-3 leading-tight">
      <a href={`${BASE}/blog/${slug}`} class="hover:text-primary-red transition-colors">
        {title}
      </a>
    </h3>

    <p class="text-sm font-medium text-black/70 leading-relaxed mb-4 line-clamp-3">
      {excerpt}
    </p>

    <a
      href={`${BASE}/blog/${slug}`}
      class={`inline-flex items-center gap-2 text-sm font-bold uppercase ${colors.hover} transition-colors`}
    >
      Read More
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="square" stroke-width="3" d="M5 12h14m-7-7l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
