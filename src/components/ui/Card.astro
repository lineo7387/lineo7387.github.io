---
interface Props {
  title: string;
  excerpt: string;
  date: Date;
  slug: string;
  image?: string;
  category: string;
  class?: string;
}

const { title, excerpt, date, slug, image, category, class: className = '' } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<article class={`bg-white border-4 border-black shadow-hard-lg card-lift relative overflow-hidden ${className}`}>
  <!-- Geometric decoration in corner -->
  <div class="absolute top-0 right-0 w-6 h-6 bg-primary-red shape-square z-10"></div>

  {image && (
    <div class="aspect-video overflow-hidden border-b-4 border-black">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover img-bauhaus"
      />
    </div>
  )}

  <div class="p-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-xs font-bold uppercase tracking-wider text-white bg-primary-blue px-2 py-1">
        {category}
      </span>
      <time class="text-xs font-medium text-black/60" datetime={date.toISOString()}>
        {formattedDate}
      </time>
    </div>

    <h3 class="text-xl font-black uppercase tracking-tight mb-3 leading-tight">
      <a href={`/blog/${slug}`} class="hover:text-primary-red transition-colors">
        {title}
      </a>
    </h3>

    <p class="text-sm font-medium text-black/70 leading-relaxed mb-4 line-clamp-3">
      {excerpt}
    </p>

    <a
      href={`/blog/${slug}`}
      class="inline-flex items-center gap-2 text-sm font-bold uppercase text-primary-blue hover:text-primary-red transition-colors"
    >
      Read More
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="square" stroke-width="3" d="M5 12h14m-7-7l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
