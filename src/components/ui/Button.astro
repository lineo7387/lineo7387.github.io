---
interface Props {
  variant?: 'primary' | 'secondary' | 'yellow' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  disabled?: boolean;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  class: className = '',
  disabled = false
} = Astro.props;

const baseStyles = 'inline-flex items-center justify-center font-bold uppercase tracking-wider transition-all duration-200 ease-out border-2 border-black btn-press disabled:opacity-50 disabled:cursor-not-allowed';

const variantStyles = {
  primary: 'bg-primary-red text-white shadow-hard-sm hover:bg-primary-red/90',
  secondary: 'bg-primary-blue text-white shadow-hard-sm hover:bg-primary-blue/90',
  yellow: 'bg-primary-yellow text-black shadow-hard-sm hover:bg-primary-yellow/90',
  outline: 'bg-white text-black shadow-hard-sm hover:bg-muted',
  ghost: 'border-none shadow-none text-black hover:bg-muted'
};

const sizeStyles = {
  sm: 'text-xs px-3 py-2',
  md: 'text-sm px-5 py-3',
  lg: 'text-base px-8 py-4'
};

const classes = `${baseStyles} ${variantStyles[variant]} ${sizeStyles[size]} ${className}`;
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} disabled={disabled}>
    <slot />
  </button>
)}
