---
import { BASE } from '../../utils/base';

const navLinks = [
  { href: `${BASE}/`, label: 'Home' },
  { href: `${BASE}/blog`, label: 'Blog' },
  { href: `${BASE}/skills`, label: 'Skills' },
  { href: `${BASE}/about`, label: 'About' },
  { href: `${BASE}/contact`, label: 'Contact' }
];

const currentPath = Astro.url.pathname.replace(new RegExp(`^${BASE}`), '') || '/';
---

<header class="bg-surface-raised border-b-4 border-foreground sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo with geometric shapes -->
      <a href={`${BASE}/`} class="flex items-center gap-2 group">
        <div class="flex items-center gap-1">
          <!-- Circle -->
          <div class="w-6 h-6 md:w-8 md:h-8 bg-brand-red shape-circle border-2 border-foreground"></div>
          <!-- Square -->
          <div class="w-6 h-6 md:w-8 md:h-8 bg-brand-blue shape-square border-2 border-foreground"></div>
          <!-- Triangle -->
          <div class="w-6 h-6 md:w-8 md:h-6 bg-brand-yellow shape-triangle border-2 border-foreground"></div>
        </div>
        <span class="font-black text-lg md:text-xl uppercase tracking-tight text-text hidden sm:block">
          Lineo<span class="text-brand-red">.</span>
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`font-bold uppercase text-sm tracking-wider transition-colors relative py-2
              ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-brand-red'
                : 'text-text hover:text-brand-blue'
              }
              after:absolute after:bottom-0 after:left-0 after:w-full after:h-1 after:bg-brand-yellow after:scale-x-0 after:transition-transform after:duration-200 hover:after:scale-x-100`}
          >
            {link.label}
          </a>
        ))}
        <!-- Theme Toggle -->
        <button
          id="theme-toggle"
          onclick="window.toggleTheme()"
          class="p-2 border-2 border-foreground bg-surface-raised hover:bg-muted transition-colors text-text"
          aria-label="Toggle dark mode"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="square" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="square" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>
      </nav>

      <!-- Mobile Menu Button + Theme Toggle -->
      <div class="flex items-center gap-2 md:hidden">
        <!-- Theme Toggle (mobile) -->
        <button
          id="theme-toggle-mobile"
          onclick="window.toggleTheme()"
          class="p-2 border-2 border-foreground bg-surface-raised hover:bg-muted transition-colors text-text"
          aria-label="Toggle dark mode"
        >
          <svg class="w-6 h-6 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="square" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg class="w-6 h-6 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="square" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>
        <!-- Menu Toggle -->
        <button
          id="menu-toggle"
          class="p-2 border-2 border-foreground bg-surface-raised hover:bg-muted transition-colors text-text"
          aria-label="Toggle menu"
        >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="square" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <nav id="mobile-menu" class="md:hidden hidden border-t-4 border-foreground bg-surface-raised">
    <div class="px-4 py-4 space-y-2">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`block font-bold uppercase text-sm tracking-wider py-3 px-4 border-2 border-foreground transition-colors
            ${currentPath === link.href
              ? 'bg-brand-red text-on-brand-red'
              : 'bg-surface-raised text-text hover:bg-muted'
            }`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');

    menuToggle?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });
  });
</script>
