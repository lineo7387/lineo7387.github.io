---
import Card from '../ui/Card.astro';

interface Props {
  title: string;
  excerpt: string;
  date: Date;
  id: string;
  image?: string;
  category: string;
  categoryIndex?: number;
}

const { title, excerpt, date, id, image, category, categoryIndex } = Astro.props;
---

<Card
  title={title}
  excerpt={excerpt}
  date={date}
  id={id}
  image={image}
  category={category}
  categoryIndex={categoryIndex}
/>
