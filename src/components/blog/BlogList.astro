---
import BlogCard from "./BlogCard.astro";
import { getCategoryIndex } from "../../utils/post";

interface PostItem {
  id: string;
  data: {
    title: string;
    description: string;
    pubDate: Date;
    heroImage?: string;
    category: string;
    planId?: string;
  };
}

interface Props {
  posts: PostItem[];
  columns?: 1 | 2 | 3;
  allPosts?: PostItem[];
}

const { posts, columns = 3, allPosts = [] } = Astro.props;

const gridCols = {
  1: "grid-cols-1",
  2: "grid-cols-1 md:grid-cols-2",
  3: "grid-cols-1 md:grid-cols-2 lg:grid-cols-3",
};

// Pre-compute category indices in frontmatter (where await is allowed)
const postsWithIndex = await Promise.all(
  posts.map(async (post) => ({
    post,
    categoryIndex: await getCategoryIndex(
      post.id,
      post.data.planId,
      post.data.category,
      allPosts,
    ),
  }))
);
---

<div class={`grid ${gridCols[columns]} gap-8`}>
  {
    postsWithIndex.map(({ post, categoryIndex }) => (
      <BlogCard
        title={post.data.title}
        excerpt={post.data.description}
        date={post.data.pubDate}
        id={post.id}
        image={post.data.heroImage}
        category={post.data.category}
        categoryIndex={categoryIndex}
      />
    ))
  }
</div>
