---
import Button from '../ui/Button.astro';
import { BASE } from '../../utils/base';
import { CATEGORY_COLORS } from '../../config/category-colors';

interface Props {
  title: string;
  excerpt: string;
  date: Date;
  id: string;
  image?: string;
  category: string;
  author: string;
}

const { title, excerpt, date, id, image, category, author } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const colors = CATEGORY_COLORS[category.toLowerCase()] ?? CATEGORY_COLORS['python'];
---

<article class="bg-white border-4 border-black shadow-hard-lg overflow-hidden">
  <div class="grid md:grid-cols-2">
    {image && (
      <div class="relative aspect-[4/3] md:aspect-auto overflow-hidden">
        <img
          src={image}
          alt={title}
          class="w-full h-full object-cover img-bauhaus"
        />
        <!-- Geometric overlay -->
        <div class="absolute top-0 right-0 w-12 h-12 bg-primary-yellow shape-triangle"></div>
      </div>
    )}

    <div class="p-8 flex flex-col justify-between">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-bold uppercase tracking-wider text-white bg-primary-red px-3 py-1">
            Featured
          </span>
          <span class={`text-xs font-bold uppercase tracking-wider px-3 py-1 ${colors.bg} ${colors.text}`}>
            {category}
          </span>
        </div>

        <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tight mb-4 leading-tight">
          <a href={`${BASE}/blog/${id}`} class="hover:text-primary-red transition-colors">
            {title}
          </a>
        </h2>

        <p class="text-base font-medium text-black/70 leading-relaxed mb-6">
          {excerpt}
        </p>

        <div class="flex items-center gap-3 text-sm text-black/60 mb-6">
          <span class="font-medium">{author}</span>
          <span class="w-1.5 h-1.5 bg-black rounded-full"></span>
          <time datetime={date.toISOString()}>{formattedDate}</time>
        </div>
      </div>

      <Button href={`${BASE}/blog/${id}`} variant="primary">
        Read Article
      </Button>
    </div>
  </div>
</article>
