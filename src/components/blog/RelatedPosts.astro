---
import { getCollection } from 'astro:content';
import BlogCard from './BlogCard.astro';
import { getCategoryIndex } from '../../utils/post';

interface Props {
  currentCategory: string;
  excludeId?: string;
}

const { currentCategory, excludeId } = Astro.props;

// Get related posts (same category, excluding current)
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter(post => post.data.category.toLowerCase() === currentCategory.toLowerCase() && post.id !== excludeId)
  .sort(() => Math.random() - 0.5)
  .slice(0, 3);

// If not enough, get other posts
if (relatedPosts.length < 2) {
  const otherPosts = allPosts
    .filter(post => post.id !== excludeId && !relatedPosts.some(p => p.id === post.id))
    .sort(() => Math.random() - 0.5)
    .slice(0, 3 - relatedPosts.length);
  relatedPosts.push(...otherPosts);
}

// Pre-compute category indices in frontmatter (where await is allowed)
const postsWithIndex = await Promise.all(
  relatedPosts.map(async (post) => ({
    post,
    categoryIndex: await getCategoryIndex(post.id, post.data.planId, post.data.category, allPosts),
  }))
);
---

{postsWithIndex.length > 0 && (
  <section class="bg-brand-blue py-16 border-b-4 border-foreground">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tight text-on-brand-blue mb-8">
        Related Articles
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {postsWithIndex.map(({ post, categoryIndex }) => (
          <div class="blog-card">
            <BlogCard
              title={post.data.title}
              excerpt={post.data.description}
              date={post.data.pubDate}
              id={post.id}
              image={post.data.heroImage}
              category={post.data.category}
              categoryIndex={categoryIndex}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
)}
