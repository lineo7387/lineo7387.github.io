---
interface Props {
  categories: string[];
  activeCategory?: string;
  searchQuery?: string;
}

const { categories, activeCategory = 'all', searchQuery = '' } = Astro.props;

const buildUrl = (category: string) => {
  const params = new URLSearchParams();
  if (category && category !== 'all') params.set('category', category);
  if (searchQuery) params.set('q', searchQuery);
  const query = params.toString();
  return query ? `/blog?${query}` : '/blog';
};
---

<div class="flex flex-wrap gap-3" id="category-filter">
  <a
    href={buildUrl('all')}
    class={`font-bold uppercase text-sm px-4 py-2 border-2 border-black transition-all btn-press
      ${activeCategory === 'all'
        ? 'bg-primary-yellow text-black shadow-hard-sm'
        : 'bg-white text-black hover:bg-muted shadow-hard-sm'
      }`}
  >
    All
  </a>
  {categories.map(category => (
    <a
      href={buildUrl(category)}
      class={`font-bold uppercase text-sm px-4 py-2 border-2 border-black transition-all btn-press
        ${activeCategory.toLowerCase() === category.toLowerCase()
          ? 'bg-primary-yellow text-black shadow-hard-sm'
          : 'bg-white text-black hover:bg-muted shadow-hard-sm'
        }`}
    >
      {category}
    </a>
  ))}
</div>
