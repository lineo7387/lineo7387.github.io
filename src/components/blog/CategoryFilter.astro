---
import { BASE } from '../../utils/base';

interface Props {
  categories: string[];
  activeCategory?: string;
}

const { categories, activeCategory = '' } = Astro.props;

const buildUrl = (category: string) => {
  if (!category || category === 'all') {
    return `${BASE}/blog`;
  }
  return `${BASE}/blog/${category.toLowerCase()}`;
};

const isAllActive = !activeCategory;
---

<div class="flex flex-wrap gap-3" id="category-filter">
  {isAllActive ? (
    <span class="font-bold uppercase text-sm px-4 py-2 border-2 border-foreground bg-brand-yellow text-on-brand-yellow shadow-hard-sm cursor-default">
      All
    </span>
  ) : (
    <a
      href={buildUrl('all')}
      class="font-bold uppercase text-sm px-4 py-2 border-2 border-foreground bg-surface-raised text-text hover:bg-muted dark:hover:bg-muted shadow-hard-sm transition-all btn-press"
    >
      All
    </a>
  )}
  {categories.map(category => {
    const isActive = activeCategory.toLowerCase() === category.toLowerCase();
    return isActive ? (
      <span class="font-bold uppercase text-sm px-4 py-2 border-2 border-foreground bg-brand-yellow text-on-brand-yellow shadow-hard-sm cursor-default">
        {category}
      </span>
    ) : (
      <a
        href={buildUrl(category)}
        class="font-bold uppercase text-sm px-4 py-2 border-2 border-foreground bg-surface-raised text-text hover:bg-muted dark:hover:bg-muted shadow-hard-sm transition-all btn-press"
      >
        {category}
      </a>
    );
  })}
</div>
