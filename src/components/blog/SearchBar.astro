---
import { BASE } from '../../utils/base';

interface Props {
  placeholder?: string;
  value?: string;
}

const { placeholder = 'Search articles...', value = '' } = Astro.props;
---

<form id="search-form" method="get" action={`${BASE}/blog`} class="relative">
  <input
    type="search"
    name="q"
    id="search-input"
    placeholder={placeholder}
    value={value}
    class="w-full px-5 py-4 pl-12 bg-white border-4 border-black font-medium text-black placeholder:text-black/40 focus:outline-none focus:border-primary-blue shadow-hard-sm"
  />
  <button
    type="button"
    id="clear-search"
    class="absolute right-4 top-1/2 -translate-y-1/2 text-black/40 hover:text-black transition-colors hidden"
    aria-label="Clear search"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="square" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  <!-- Search icon -->
  <div class="absolute left-4 top-1/2 -translate-y-1/2 text-black/40 pointer-events-none">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="square" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
  </div>
</form>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const clearBtn = document.getElementById('clear-search');

  clearBtn?.addEventListener('click', () => {
    if (searchInput) {
      searchInput.value = '';
      clearBtn.classList.add('hidden');
      const url = new URL(window.location.href);
      url.searchParams.delete('q');
      window.location.href = url.toString();
    }
  });

  searchInput?.addEventListener('input', () => {
    clearBtn?.classList.toggle('hidden', !searchInput!.value);
  });
</script>
