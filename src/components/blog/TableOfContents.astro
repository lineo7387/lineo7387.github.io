---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

const tocItems = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{tocItems.length > 0 && (
  <nav class="toc" aria-label="Table of contents">
    <div class="toc-inner">
      <div class="toc-header">CONTENTS</div>
      <ul class="toc-list">
        {tocItems.map(heading => (
          <li class={`toc-item toc-depth-${heading.depth}`}>
            <a href={`#${heading.slug}`} class="toc-link" data-heading={heading.slug}>
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
)}

<style is:global>
  .toc {
    padding: 0;
  }

  .toc-inner {
    background: var(--color-white);
    border: 2px solid var(--color-foreground);
    border-left: 4px solid var(--color-primary-blue);
    padding: 1rem;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
  }

  /* Custom scrollbar — Bauhaus color scheme */
  .toc-inner::-webkit-scrollbar {
    width: 6px;
  }

  .toc-inner::-webkit-scrollbar-track {
    background: var(--color-primary-yellow);
    border-left: 1px solid var(--color-foreground);
  }

  .toc-inner::-webkit-scrollbar-thumb {
    background: var(--color-foreground);
  }

  .toc .toc-inner::-webkit-scrollbar-thumb:hover {
    background: var(--color-primary-red);
  }

  .toc-header {
    font-family: var(--font-family-outfit);
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-foreground);
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-foreground);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-link {
    display: block;
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-foreground);
    text-decoration: none;
    border-left: 3px solid transparent;
    transition: all 0.15s ease;
  }

  .toc-link:hover {
    background-color: var(--color-primary-yellow);
    border-left-color: var(--color-primary-blue);
  }

  .toc-link.active {
    background-color: var(--color-primary-yellow);
    border-left-color: var(--color-primary-red);
    font-weight: 800;
  }

  .toc-depth-3 .toc-link {
    padding-left: 1.5rem;
    font-size: 0.8rem;
    color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
  }
</style>

<script>
  function initTOC() {
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link[data-heading]');
    if (!links.length) return;

    const headingIds = Array.from(links).map(link => link.dataset.heading!);
    const headingElements = headingIds
      .map(id => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    let current = '';

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            current = entry.target.id;
          }
        });
        links.forEach(link => {
          link.classList.toggle('active', link.dataset.heading === current);
        });
      },
      {
        rootMargin: '-80px 0px -60% 0px',
        threshold: 0,
      }
    );

    headingElements.forEach(el => observer.observe(el));

    links.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const id = link.dataset.heading!;
        const target = document.getElementById(id);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.pushState(null, '', `#${id}`);
        }
      });
    });
  }

  initTOC();
  document.addEventListener('astro:after-swap', initTOC);
</script>
