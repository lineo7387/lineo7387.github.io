---
interface Props {
  id: string;
}
const { id } = Astro.props;
---

<section class="mt-12 pt-8 border-t-4 border-foreground" id="comments">
  <h2
    class="text-2xl font-black uppercase tracking-tight text-text mb-6 flex items-center gap-3"
  >
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="square"
    >
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
      ></path>
    </svg>
    评论
  </h2>
  <div class="giscus"></div>
</section>

<script is:inline>
  function loadGiscus() {
    var s = document.createElement('script');
    s.src = 'https://giscus.app/client.js';
    s.crossOrigin = 'anonymous';
    s.async = true;
    s.dataset.repo = 'lineo7387/lineo7387.github.io';
    s.dataset.repoId = 'R_kgDOR8IPRQ';
    s.dataset.category = 'Announcements';
    s.dataset.categoryId = 'DIC_kwDOR8IPRc4C7HTE';
    s.dataset.mapping = 'pathname';
    s.dataset.strict = '0';
    s.dataset.reactionsEnabled = '1';
    s.dataset.emitMetadata = '0';
    s.dataset.inputPosition = 'bottom';
    s.dataset.theme = 'https://lineo7387.github.io/themes/giscus-light.css';
    s.dataset.themeURL = 'https://lineo7387.github.io/themes/giscus-dark.css';
    s.dataset.lang = 'zh-CN';
    s.dataset.loading = 'lazy';
    var giscusDiv = document.querySelector('.giscus');
    if (giscusDiv) {
      giscusDiv.appendChild(s);
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadGiscus);
  } else {
    loadGiscus();
  }
</script>
