---
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import { BASE } from "../utils/base";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Lineo's Blog - Personal tech blog about web development, design, and more.",
  ogImage = `${BASE}/og-default.png`,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    <title>{title} | Lineo's Blog</title>
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline define:vars={{ BASE }}>
      // 阻止点击同页面链接触发 ClientRouter 导航
      // 在 astro:page-load 时注册，保证只在首次加载时添加一次
      function blockSamePageNav(e) {
        var target = e.target.closest ? e.target.closest('a') : null;
        if (!target) return;
        var href = target.href;
        if (!href) return;
        try {
          var url = new URL(href, location.href);
          if (url.pathname === location.pathname && url.search === location.search) {
            e.preventDefault();
            if (url.hash) {
              var el = document.querySelector(url.hash);
              if (el) el.scrollIntoView({ behavior: 'smooth' });
            }
          }
        } catch (err) {}
      }
      document.addEventListener('astro:page-load', function () {
        // 首次加载时注册
        document.addEventListener('click', blockSamePageNav, true);
      }, { once: true });
    </script>
    <!-- Theme initialization + toggle -->
    <script is:inline>
      // 主题初始化 - 在每次页面加载时执行（包括客户端路由导航）
      function initTheme() {
        var saved = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var isDark = saved === 'dark' || (!saved && prefersDark);
        document.documentElement.classList.toggle('dark', isDark);
      }

      // 监听页面加载事件（包括首次加载和客户端路由导航）
      document.addEventListener('astro:page-load', function () {
        initTheme();

        // 同步系统偏好（只在首次加载时设置监听器）
        if (!window._themeSystemListenerSet) {
          window._themeSystemListenerSet = true;
          window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function (e) {
            if (!localStorage.getItem('theme')) {
              document.documentElement.classList.toggle('dark', e.matches);
            }
          });
        }
      });

      window.toggleTheme = function () {
        var isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      };
    </script>
  </body>
</html>
